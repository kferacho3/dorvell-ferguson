{
  "name": "dorvell-ferguson-portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/kferacho3/dorvell-ferguson.git"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "scrape:portfolio": "tsx scripts/scrape-dorvell-portfolio.ts",
    "scrape:instagram": "tsx scripts/scrape-fergphotography-instagram.ts",
    "process:images": "tsx scripts/process-dorvell-images.ts",
    "optimize:videos": "node scripts/optimize-dorvell-videos.mjs",
    "optimize:photomode": "node scripts/optimize-dorvell-photomode.mjs",
    "optimize:creative": "npm run optimize:videos && npm run optimize:photomode",
    "upload:assets": "node scripts/upload-dorvell-assets.mjs",
    "upload:assets:dry-run": "node scripts/upload-dorvell-assets.mjs --dry-run",
    "build:content": "npm run scrape:portfolio && npm run scrape:instagram && npm run process:images",
    "verify:portfolio-data": "tsx scripts/verify-dorvell-data.ts",
    "curation:build": "tsx scripts/curation/report-to-json.ts"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "next": "^16.2.9",
    "playwright": "^1.49.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sharp": "^0.33.5",
    "three": "^0.171.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
